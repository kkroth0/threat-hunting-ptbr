// HEARTH H092 - candidato inicial KQL
// Fonte: https://github.com/THORCollective/HEARTH/blob/main/Flames/H092.md
// Hipótese: um adversário está realizando varredura automatizada para endpoints de exportação do agente AI não autenticados API (padrão CVE-2026-25253), visando implantações de agente AI hospedadas na nuvem, para coletar credenciais de serviço LLM armazenadas para baixo...
// Padrão: Persistência de endpoint e cadeia de evasão de defesa
// Cobertura: Starter KQL - validar em Sentinel
// Prioridade: P2 (45)
// Tabelas: SecurityEvent, WindowsEvent, TrendMicro_XDR_OAT_CL, TrendMicro_XDR_WORKBENCH_CL, Cloudflare_CL, CommonSecurityLog, AzureDiagnostics, AppRequests, AppTraces, Syslog, SigninLogs, AuditLogs
// Valide a disponibilidade da tabela, nomes de campos, limites e falsos positivos antes de usar como detecção.
let lookback = 14d;
let huntTerms = dynamic(["T1552", "credential access", "cve 2026 25253", "ai agent security", "api key exfil", "openclaw", "clawdbot", "H092", "performing", "automated", "scanning", "unauthenticated", "agent", "export", "endpoints", "CVE-2026-25253", "pattern", "targeting", "cloud-hosted", "deployments", "harvest", "stored", "powershell", "cmd.exe", "wscript", "cscript", "mshta", "rundll32", "regsvr32", "CurrentVersion\\Run", "Scheduled", "Service", "Registry", "Image File Execution Options", "SilentProcessExit", "Debugger", "Driver", "DLL"]);
union withsource=SourceTable isfuzzy=true
    SecurityEvent,
    WindowsEvent,
    TrendMicro_XDR_OAT_CL,
    TrendMicro_XDR_WORKBENCH_CL
| where TimeGenerated >= ago(lookback)
| extend SearchBlob = tostring(pack_all())
| where SearchBlob has_any (huntTerms)
| extend HuntId = "H092", SourceUrl = "https://github.com/THORCollective/HEARTH/blob/main/Flames/H092.md"
| project TimeGenerated, HuntId, SourceTable, SourceUrl, SearchBlob
| order by TimeGenerated desc
