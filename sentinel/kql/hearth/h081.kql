// HEARTH H081 - candidato inicial KQL
// Fonte: https://github.com/THORCollective/HEARTH/blob/main/Flames/H081.md
// Hipótese: um adversário está publicando pacotes npm typosquatted com injeção de servidor MCP visando ambientes de desenvolvedor usando assistentes de codificação AI para coletar chaves SSH, credenciais de nuvem e chaves LLM API por meio de injeção imediata.
// Padrão: exploração de aplicativos públicos e revisão de webshell
// Cobertura: Starter KQL - validar em Sentinel
// Prioridade: P1 (72)
// Tabelas: CommonSecurityLog, NetskopeEventsNetwork_CL, NetskopeEventsConnection_CL, Cloudflare_CL, NetskopeAlerts_CL, AzureDiagnostics, AppRequests, AppTraces, Syslog, SigninLogs, AuditLogs, IdentityInfo
// Valide a disponibilidade da tabela, nomes de campos, limites e falsos positivos antes de usar como detecção.
let lookback = 1d;
let huntTerms = dynamic(["T1195.002", "T1555", "T1119", "initial access", "credential access", "collection", "npm", "supply chain", "mcp", "ai coding assistant", "H081", "publishing", "typosquatted", "packages", "server", "injection", "targeting", "developer", "environments", "coding", "assistants", "harvest", "POST", "GET", "webshell", "cmd=", "whoami", "bash", "powershell", "rce", "ssrf", "jndi"]);
union withsource=SourceTable isfuzzy=true
    Cloudflare_CL,
    CommonSecurityLog,
    AzureDiagnostics,
    AppRequests,
    AppTraces,
    Syslog
| where TimeGenerated >= ago(lookback)
| extend SearchBlob = tostring(pack_all())
| where SearchBlob has_any (huntTerms)
| extend HuntId = "H081", SourceUrl = "https://github.com/THORCollective/HEARTH/blob/main/Flames/H081.md"
| project TimeGenerated, HuntId, SourceTable, SourceUrl, SearchBlob
| order by TimeGenerated desc
