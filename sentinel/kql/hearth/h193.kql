// HEARTH H193 - candidato inicial KQL
// Fonte: https://github.com/THORCollective/HEARTH/blob/main/Flames/H193.md
// Hipótese: Os adversários atraem os usuários para executar instaladores falsos da marca AI (*AI*Setup.exe, deepseek-v4*.exe, *Flux*Ai*.exe) que colocam um pythonw.exe + LICENSE.txt renomeado em %AppData%\Local e execute um beacon de download do Python...
// Padrão: Rede, DNS e correlação de anomalia de saída
// Cobertura: Starter KQL - validar em Sentinel
// Prioridade: P2 (52)
// Tabelas: SecurityEvent, WindowsEvent, TrendMicro_XDR_OAT_CL, TrendMicro_XDR_WORKBENCH_CL, CommonSecurityLog, NetskopeEventsNetwork_CL, NetskopeEventsConnection_CL, Cloudflare_CL, NetskopeAlerts_CL, SigninLogs, AuditLogs, IdentityInfo
// Valide a disponibilidade da tabela, nomes de campos, limites e falsos positivos antes de usar como detecção.
let lookback = 14d;
let huntTerms = dynamic(["T1204.002", "infostealer", "vidar", "ai lure", "masquerading", "fake installer", "H193", "lure", "users", "running", "AI-branded", "fake", "installers", "Setup.exe", "deepseek-v4", "Flux", "that", "drop", "renamed", "pythonw.exe", "LICENSE.txt", "AppData%\\Local", "dns", "http", "https", "ssh", "rdp", "smb", "tunnel", "beacon", "c2", "block", "deny"]);
union withsource=SourceTable isfuzzy=true
    CommonSecurityLog,
    Cloudflare_CL,
    NetskopeEventsNetwork_CL,
    NetskopeEventsConnection_CL,
    NetskopeAlerts_CL
| where TimeGenerated >= ago(lookback)
| extend SearchBlob = tostring(pack_all())
| where SearchBlob has_any (huntTerms)
| extend HuntId = "H193", SourceUrl = "https://github.com/THORCollective/HEARTH/blob/main/Flames/H193.md"
| summarize
    Events = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    Samples = make_set(SearchBlob, 3)
    by HuntId, SourceUrl, SourceTable
| order by Events desc
