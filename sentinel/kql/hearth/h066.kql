// HEARTH H066 - candidato inicial KQL
// Fonte: https://github.com/THORCollective/HEARTH/blob/main/Flames/H066.md
// Hipótese: um adversário está implantando extensões de navegador maliciosas que se fazem passar por ferramentas de produtividade AI para roubar tokens de sessão e dados de conversação de plataformas AI visando usuários de ChatGPT, DeepSeek e serviços semelhantes...
// Padrão: correlação de abuso de identidade token/OAuth
// Cobertura: Starter KQL - validar em Sentinel
// Prioridade: P2 (46)
// Tabelas: SigninLogs, AuditLogs, IdentityInfo, BehaviorAnalytics, UserPeerAnalytics, SecurityEvent, WindowsEvent, TrendMicro_XDR_OAT_CL, TrendMicro_XDR_WORKBENCH_CL, Syslog, Heartbeat, CommonSecurityLog
// Valide a disponibilidade da tabela, nomes de campos, limites e falsos positivos antes de usar como detecção.
let lookback = 7d;
let huntTerms = dynamic(["T1528", "T1185", "credential access", "browser extension", "ai tokens", "chatgpt", "session hijack", "H066", "deploying", "malicious", "browser", "extensions", "that", "impersonate", "productivity", "tools", "steal", "session", "tokens", "conversation", "platforms", "targeting"]);
union withsource=SourceTable isfuzzy=true
    SigninLogs,
    AuditLogs,
    OfficeActivity
| where TimeGenerated >= ago(lookback)
| extend SearchBlob = tostring(pack_all())
| where SearchBlob has_any (huntTerms)
    or SearchBlob has_any ("deviceCode", "oauth", "refresh token", "consent", "service principal", "Microsoft Graph")
| extend HuntId = "H066", SourceUrl = "https://github.com/THORCollective/HEARTH/blob/main/Flames/H066.md"
| project TimeGenerated, HuntId, SourceTable, SourceUrl, SearchBlob
| order by TimeGenerated desc
